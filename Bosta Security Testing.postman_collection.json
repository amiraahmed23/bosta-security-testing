        {
          "name": "XSS Injection",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"SEC-008: XSS payload in name is rejected or sanitized\", function () {\r",
                  "    pm.expect(pm.response.code).to.be.oneOf([400, 200]);\r",
                  "    if (pm.response.code === 200) {\r",
                  "        var jsonResponse = pm.response.json();\r",
                  "        pm.test(\"XSS script not stored in response\", function() {\r",
                  "            pm.expect(JSON.stringify(jsonResponse)).to.not.include(\"<script>\");\r",
                  "        });\r",
                  "    }\r",
                  "});"
                ],
